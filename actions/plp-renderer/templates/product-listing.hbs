<div class="product-list-page">
  <div>
    <div>urlPath</div>
    <div>{{categorySlug}}</div>
  </div>
  <div>
    <div>
      <nav aria-label="Breadcrumb">
        <ol>
          {{#each breadcrumbs}}
          <li><a href="{{url}}">{{name}}</a></li>
          {{/each}}
        </ol>
      </nav>
      {{#if categoryDescription}}
      <div>{{{categoryDescription}}}</div>
      {{/if}}
      {{#if hasProducts}}
      <ul>
        {{#each products}}
        <li>
          <a href="{{url}}">
            {{#if image}}<img src="{{image}}" alt="{{name}}">{{/if}}
            <span>{{name}}</span>
          </a>
        </li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
  </div>
</div>